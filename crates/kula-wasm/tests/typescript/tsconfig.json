{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "noEmit": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "isolatedModules": true,
        "skipLibCheck": false,
        "allowImportingTsExtensions": false
    },
    "include": [
        "usage.ts"
    ]
}
