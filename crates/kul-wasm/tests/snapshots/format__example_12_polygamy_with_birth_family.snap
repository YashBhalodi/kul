source: crates/kul-wasm/tests/format.rs
expression: formatted
---
# Example 12: Pure-host polygamy embedded in a multi-generation tree.
#
# - Ramesh and Sita marry in 1945; Devraj is their biological son.
# - Devraj is concurrently married to Meera (from 1990) and Alice (from 1992).
# - Priya is the biological daughter of Devraj and Alice.
# - Both of Devraj's marriages are ongoing.
#
# Unlike example 04 (where Devraj has no birth family and the polygamy
# floats as a mini-component), here the polygamous person sits inside
# his birth family. P8's amendment for issue #142 (see ADR-0021) means
# Devraj renders as one canonical card in Ramesh + Sita's children
# row, hosting both bars side-by-side; Meera and Alice each appear
# canonically as a co-spouse adjacent to Devraj. Priya's birth edge
# attaches to the m_devraj_alice bar specifically (P9).

# ---- Generation 1 (founders, no birth families) ----
person ramesh  name:"Ramesh Kumar"  gender:male    born:1920-03-15
person sita    name:"Sita Kumar"    gender:female  born:1922-08-22

marriage m_ramesh_sita ramesh sita  start:1945-06-10

# ---- Generation 2: Devraj (bio child of m_ramesh_sita) and his spouses ----
person devraj  name:"Devraj Kumar"  gender:male    born:1948-06-21
  birth m_ramesh_sita
person meera   name:"Meera"         gender:female  born:1955-03-08
person alice   name:"Alice Sharma"  gender:female  born:1950-04-12

marriage m_devraj_meera devraj meera  start:1990-01-01
marriage m_devraj_alice devraj alice  start:1992-02-14

# ---- Generation 3: Priya (bio child of m_devraj_alice) ----
person priya  name:"Priya Kumar"  gender:female  born:1994-12-01
  birth m_devraj_alice
