# Example 15: N=3 polygamy hub.
#
# - Devraj is concurrently married to Meera (1990), Alice (1992), and
#   Diana (1994); all three marriages ongoing.
# - Devraj hosts all three (per R14: polygamy hub must host all
#   concurrent un-ended marriages).
# - One child per marriage exercises P9 per-bar edge attachment and
#   demonstrates that half-siblings render in distinct sub-trees
#   below their own marriage bar.

person devraj  name:"Devraj Kumar"  gender:male    born:1948-06-21
person meera   name:"Meera"         gender:female  born:1955-03-08
person alice   name:"Alice Sharma"  gender:female  born:1950-04-12
person diana   name:"Diana Roy"     gender:female  born:1960-09-15

person asha   name:"Asha Kumar"   gender:female  born:1991-04-12
  birth m_devraj_meera
person priya  name:"Priya Kumar"  gender:female  born:1994-12-01
  birth m_devraj_alice
person rohan  name:"Rohan Kumar"  gender:male    born:1996-07-22
  birth m_devraj_diana

marriage m_devraj_meera devraj meera  start:1990-01-01
marriage m_devraj_alice devraj alice  start:1992-02-14
marriage m_devraj_diana devraj diana  start:1994-08-30
