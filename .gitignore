# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# Logs and temp
*.log
*.tmp

# VSCode extension build artifacts
*.vsix
node_modules/

# JS workspace build artifacts. Per-package dist/, the extension's bundled
# extension.js, and `media/preview/` (populated by `npm run build:preview` /
# `scripts/copy-preview-assets.mjs` before `vsce package` — never authored
# by hand).
packages/*/dist/
editor/vscode/out/
editor/vscode/media/preview/

# Rust
/target
**/*.rs.bk
Cargo.lock.bak

# WASM build output (wasm-pack). The generated `.d.ts` is extracted into
# `crates/kul-wasm/types/` and committed; everything else is artifact-only.
crates/kul-wasm/pkg/
