{
  "name": "kul",
  "displayName": "KulLang",
  "description": "Syntax highlighting and editor support for Kul (.kul) kinship-description files.",
  "version": "0.4.1",
  "publisher": "YashBhalodi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YashBhalodi/kul.git"
  },
  "homepage": "https://github.com/YashBhalodi/kul",
  "bugs": {
    "url": "https://github.com/YashBhalodi/kul/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "icon": "images/icon.png",
  "keywords": [
    "kul",
    "KulLang",
    "kinship",
    "genealogy",
    "family-tree"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "typecheck": "tsc -p . --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bundle": "esbuild src/extension.ts --bundle --platform=node --target=node18 --external:vscode --outfile=out/extension.js --minify",
    "build": "npm run typecheck && npm run bundle",
    "watch": "esbuild src/extension.ts --bundle --platform=node --target=node18 --external:vscode --outfile=out/extension.js --sourcemap --watch",
    "vscode:prepublish": "npm run build",
    "fetch-server": "node scripts/fetch-server-binaries.mjs",
    "package": "vsce package",
    "package:bundled": "npm run fetch-server && vsce package",
    "publish": "vsce publish",
    "publish:bundled": "npm run fetch-server && vsce publish"
  },
  "contributes": {
    "languages": [
      {
        "id": "kul",
        "aliases": [
          "Kul",
          "KulLang"
        ],
        "extensions": [
          ".kul"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./images/kul-file-icon.svg",
          "dark": "./images/kul-file-icon.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "kul",
        "scopeName": "source.kul",
        "path": "./syntaxes/kul.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "kul",
        "path": "./snippets/kul.json"
      }
    ],
    "iconThemes": [
      {
        "id": "kul-icons",
        "label": "Kul File Icons",
        "path": "./icons/kul-icon-theme.json"
      }
    ],
    "commands": [
      {
        "command": "kul.export.json",
        "title": "Export to JSON",
        "category": "Kul"
      },
      {
        "command": "kul.export.cytoscape",
        "title": "Export to Cytoscape JSON",
        "category": "Kul"
      },
      {
        "command": "kul.preview.show",
        "title": "Show Preview",
        "category": "Kul"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "kul.export.json",
          "when": "editorLangId == kul"
        },
        {
          "command": "kul.export.cytoscape",
          "when": "editorLangId == kul"
        },
        {
          "command": "kul.preview.show",
          "when": "editorLangId == kul"
        }
      ]
    },
    "configuration": {
      "title": "Kul",
      "properties": {
        "kul.serverPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to a `kul-lsp` binary. When set, overrides the bundled binary. Use this to point at a locally-built `kul-lsp` (e.g. `target/debug/kul-lsp`) for development. Leave empty to use the bundled binary."
        },
        "kul.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace LSP messages between VSCode and the Kul language server. Output appears in the `Kul LSP` channel."
        }
      }
    },
    "configurationDefaults": {
      "[kul]": {
        "editor.defaultFormatter": "YashBhalodi.kul",
        "editor.formatOnSave": true,
        "editor.semanticHighlighting.enabled": true
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
